{
    "name": "moncine/app",
    "description": "Moncine — gestion de collection cinéma (paquet YunoHost)",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Stéphane MATER"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload-dev": {
        "psr-4": {
            "Moncine\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    }
}

#!/bin/bash
# Désinstallation Moncine — paquet YunoHost

set -euo pipefail

source _common.sh
source /usr/share/yunohost/helpers

ynh_script_progression "Retrait de la configuration système de ${app}…"

ynh_config_remove_nginx
ynh_config_remove_phpfpm

# data_dir et install_dir sont gérés par le cœur YunoHost (conservés sauf --purge)

ynh_script_progression "Désinstallation de ${app} terminée."
